{
  "name": "electron-starter",
  "type": "module",
  "version": "0.0.0",
  "description": "An Electron application with React and TypeScript",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "main": "./out/main/index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck:node": "tsgo --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "bump": "bumpp -y -q",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "[ -n \"$CI\" ] || lefthook install",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "bun run build && electron-builder --mac",
    "build:linux": "bun run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@orpc/client": "^1.14.1",
    "@orpc/server": "^1.14.1",
    "@orpc/tanstack-query": "^1.14.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-conf": "^1.3.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.33",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.0.2",
    "@typescript/native-preview": "7.0.0-dev.20250828.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^11.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lefthook": "^2.1.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.0-beta.6"
  },
  "trustedDependencies": [
    "electron",
    "lefthook"
  ]
}
